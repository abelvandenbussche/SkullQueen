<Window x:Class="SkullQueen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SkullQueen"
        mc:Ignorable="d"
        Title="skull Queen" Height="600" Width="1000">
    <Grid>
        <Canvas x:Name="MainCanvas" Margin="0,0,0,0">
            <Canvas x:Name="HandCanvas" Height="100" Width="700" Canvas.Left="150" Canvas.Top="451" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Canvas x:Name="Middle" Width="400" Height="175" Canvas.Left="300" Canvas.Top="205" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Canvas x:Name="PlayersCanvas" Height="200" HorizontalAlignment="Left" VerticalAlignment="Top" Width="800" Canvas.Left="100" Canvas.Top="10"></Canvas>
        </Canvas>
    </Grid>
</Window>
