<UserControl x:Class="SkullQueenClient.LobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SkullQueenClient"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <ListBox x:Name="LobbyList" d:ItemsSource="{d:SampleData ItemCount=8}" Margin="25,75,0,0" Width="150" Height="170" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="61,27,0,0" TextWrapping="Wrap" Text="Lobby" VerticalAlignment="Top" FontSize="30"/>
        <TextBlock x:Name="UsernameHeader" HorizontalAlignment="Left" Margin="201,79,0,0" TextWrapping="Wrap" Text="Username" VerticalAlignment="Top" FontSize="20"/>
        <TextBox x:Name="UsernameTextBox" HorizontalAlignment="Left" Margin="201,115,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" AcceptsReturn="False"/>
        <Button Content="Find game" HorizontalAlignment="Right" Margin="0,0,30,30" VerticalAlignment="Bottom" FontSize="50" Click="Button_Click"/>
        <Button x:Name="ReadyUpButton" Content="READY?" HorizontalAlignment="Right" Margin="0,0,30,30" VerticalAlignment="Bottom" FontSize="50" Visibility="Hidden" Click="ReadyUpButton_Click"/>
        <Button x:Name="BotButton" Content="Add Bot" HorizontalAlignment="Left" Margin="26,0,0,30" VerticalAlignment="Bottom" Height="50" Width="90" FontSize="20" Visibility="Hidden" Click="BotButton_Click"/>
        <Button x:Name="BotRemovalButton" Content="Remove Bot" HorizontalAlignment="Left" Margin="127,0,0,30" VerticalAlignment="Bottom" Height="50" Width="118" FontSize="20" Visibility="Hidden" Click="BotRemovalButton_Click"/>

        <Grid x:Name="DifficultyButtonGrid" Margin="25,0,0,100" VerticalAlignment="Bottom" HorizontalAlignment="Left" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Text="Bot Difficulty:" Grid.Row="0"/>
            <RadioButton x:Name="EasyBotRadioButton" Grid.Row="1" Content="Easy" HorizontalAlignment="Left" VerticalAlignment="Top" GroupName="BotDifficulty" IsChecked="True" Checked="BotDifficultyRadioButton_Checked"/>
            <RadioButton x:Name="MediumBotRadioButton" Grid.Row="2" Content="Medium" HorizontalAlignment="Left" VerticalAlignment="Top" GroupName="BotDifficulty" IsChecked="False" Checked="BotDifficultyRadioButton_Checked"/>
            <RadioButton x:Name="HardBotRadioButton" Grid.Row="3" Content="Hard" HorizontalAlignment="Left" VerticalAlignment="Top" GroupName="BotDifficulty" IsChecked="False" Checked="BotDifficultyRadioButton_Checked"/>
        </Grid>
    </Grid>
</UserControl>
