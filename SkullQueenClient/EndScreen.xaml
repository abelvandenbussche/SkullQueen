<UserControl x:Class="SkullQueenClient.EndScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SkullQueenClient"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <ListView x:Name="ScoringList" HorizontalAlignment="Center" VerticalAlignment="Center" Height="450" Width="284">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Place" DisplayMemberBinding="{Binding Place}" Width="60"/>
                    <GridViewColumn Header="Player" DisplayMemberBinding="{Binding Name}" Width="120"/>
                    <GridViewColumn Header="Score" DisplayMemberBinding="{Binding Score}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
